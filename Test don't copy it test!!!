-- LOAD SAVED ON START
-- ══════════════════════════════════════════════
task.spawn(function()
    local saved = loadFromFile()
    if #saved > 0 then
        StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 80)
        StatusLabel.Text = "Loading saved roster..."
        for _, entry in ipairs(saved) do
            local iok, url = pcall(function()
                return Players:GetUserThumbnailAsync(
                    entry.userId,
                    Enum.ThumbnailType.HeadShot,
                    Enum.ThumbnailSize.Size100x100)
            end)
            entry.avatarUrl = (iok and url) and url or ""
            table.insert(cardList, entry)
        end
        currentIndex = 1
        rebuildCarousel()
        StatusLabel.TextColor3 = Color3.fromRGB(100, 215, 120)
        StatusLabel.Text = "✓ Roster loaded!"
        task.wait(2)
        StatusLabel.Text = ""
    end
end)

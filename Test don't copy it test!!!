local SAVE_FILE = "transform_roster.json"

local function saveToFile()
    local data = {}
    for _, d in ipairs(cardList) do
        table.insert(data, {name = d.name, userId = d.userId})
    end
    local ok = pcall(function()
        writefile(SAVE_FILE, game:GetService("HttpService"):JSONEncode(data))
    end)
end

local function loadFromFile()
    local ok, content = pcall(function()
        return readfile(SAVE_FILE)
    end)
    if not ok or not content or content == "" then return {} end
    local dok, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(content)
    end)
    return (dok and data) and data or {}
end


-- ══════════════════════════════════════════════
-- ADD PLAYER
-- ══════════════════════════════════════════════
local function searchAndAdd(username)
    username = username:match("^%s*(.-)%s*$")
    if username == "" then return end
    for _, d in ipairs(cardList) do
        if d.name:lower() == username:lower() then
            StatusLabel.TextColor3 = Color3.fromRGB(220, 180, 50)
            StatusLabel.Text = username .. " already added"
            return
        end
    end
    StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 80)
    StatusLabel.Text = "Searching..."

    task.spawn(function()
        local ok, userId = pcall(function()
            return Players:GetUserIdFromNameAsync(username)
        end)
        if not ok or not userId then
            StatusLabel.TextColor3 = Color3.fromRGB(220, 80, 80)
            StatusLabel.Text = "User not found"
            return
        end
        local iok, url = pcall(function()
            return Players:GetUserThumbnailAsync(userId,
                Enum.ThumbnailType.HeadShot,
                Enum.ThumbnailSize.Size100x100)
        end)
        local avatarUrl = (iok and url) and url or ""
        table.insert(cardList, {name = username, userId = userId, avatarUrl = avatarUrl})
        currentIndex = #cardList
        saveToFile()
        rebuildCarousel()
        if rosterOpen then rebuildRosterList() end
        StatusLabel.TextColor3 = Color3.fromRGB(100, 215, 120)
        StatusLabel.Text = "Added: " .. username
        SearchBox.Text = ""
    end)
end

AddBtn.MouseButton1Click:Connect(function() searchAndAdd(SearchBox.Text) end)
SearchBox.FocusLost:Connect(function(ep) if ep then searchAndAdd(SearchBox.Text) end end)


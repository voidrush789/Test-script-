-- ══════════════════════════════════════════════
-- CAROUSEL
-- ══════════════════════════════════════════════
rebuildCarousel = function()
    for _, c in ipairs(CarouselTrack:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    if #cardList == 0 then
        SelectedLabel.Text = "No player selected"
        selectedPlayer = nil
        rebuildRosterList()
        return
    end

    if currentIndex < 1 then currentIndex = 1 end
    if currentIndex > #cardList then currentIndex = #cardList end

    for i, data in ipairs(cardList) do
        local offset = (i - currentIndex) * (CARD_W + GAP)
        local xPos = CENTER_X + offset
        local isCentre = (i == currentIndex)

        local tile = Instance.new("Frame", CarouselTrack)
        tile.Name = "Tile_"..i
        tile.Size = UDim2.new(0, CARD_W, 0, CARD_H)
        tile.Position = UDim2.new(0, xPos, 0.5, -CARD_H/2)
        tile.BackgroundColor3 = Color3.fromRGB(22, 22, 38)
        tile.BackgroundTransparency = isCentre and 0 or 0.35
        tile.BorderSizePixel = 0
        Instance.new("UICorner", tile).CornerRadius = UDim.new(0, 12)

        local tStroke = Instance.new("UIStroke", tile)
        tStroke.Thickness = isCentre and 2 or 0.8
        tStroke.Color = isCentre
            and Color3.fromRGB(100, 160, 255)
            or Color3.fromRGB(35, 35, 60)

        local img = Instance.new("ImageLabel", tile)
        img.Size = UDim2.new(1, -8, 0, CARD_H - 28)
        img.Position = UDim2.new(0, 4, 0, 4)
        img.BackgroundColor3 = Color3.fromRGB(15, 15, 28)
        img.BackgroundTransparency = isCentre and 0 or 0.5
        img.Image = data.avatarUrl or ""
        img.ScaleType = Enum.ScaleType.Fit
        Instance.new("UICorner", img).CornerRadius = UDim.new(0, 9)

        if not data.avatarUrl or data.avatarUrl == "" then
            local ph = Instance.new("TextLabel", img)
            ph.Size = UDim2.new(1, 0, 1, 0)
            ph.BackgroundTransparency = 1
            ph.Text = "?"
            ph.TextSize = 26
            ph.Font = Enum.Font.GothamBold
            ph.TextColor3 = Color3.fromRGB(60, 60, 100)
        end

        local nameL = Instance.new("TextLabel", tile)
        nameL.Size = UDim2.new(1, -4, 0, 20)
        nameL.Position = UDim2.new(0, 2, 1, -22)
        nameL.BackgroundTransparency = 1
        nameL.Text = data.name
        nameL.TextSize = isCentre and 9 or 8
        nameL.Font = Enum.Font.GothamBold
        nameL.TextColor3 = isCentre
            and Color3.fromRGB(220, 230, 255)
            or Color3.fromRGB(100, 110, 150)
        nameL.TextTruncate = Enum.TextTruncate.AtEnd
        nameL.TextXAlignment = Enum.TextXAlignment.Center

        if isCentre then
            local del = Instance.new("TextButton", tile)
            del.Size = UDim2.new(0, 18, 0, 18)
            del.Position = UDim2.new(1, -20, 0, 2)
            del.BackgroundColor3 = Color3.fromRGB(190, 40, 40)
            del.BorderSizePixel = 0
            del.Text = "×"
            del.TextColor3 = Color3.fromRGB(255, 255, 255)
            del.TextSize = 11
            del.Font = Enum.Font.GothamBold
            del.ZIndex = 8
            Instance.new("UICorner", del).CornerRadius = UDim.new(0, 5)

            local capData, capIdx = data, i
            del.MouseButton1Click:Connect(function()
                table.remove(cardList, capIdx)
                if currentIndex > #cardList and currentIndex > 1 then
                    currentIndex -= 1
                end
                if selectedPlayer and selectedPlayer.Name == capData.name then
                    selectedPlayer = nil
                end
                saveToFile()
                rebuildCarousel()
                if #cardList > 0 then
                    local cur = cardList[currentIndex]
                    selectedPlayer = {Name = cur.name, UserId = cur.userId}
                    SelectedLabel.Text = cur.name
                else
                    SelectedLabel.Text = "No player selected"
                end
            end)
        end
    end

    local cur = cardList[currentIndex]
    if cur then
        selectedPlayer = {Name = cur.name, UserId = cur.userId}
        SelectedLabel.Text = cur.name
    end

    rebuildRosterList()
end

-- ══════════════════════════════════════════════
-- SWIPE
-- ══════════════════════════════════════════════
local swipeStart = nil
SwipeRegion.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch
        or input.UserInputType == Enum.UserInputType.MouseButton1 then
        swipeStart = input.Position.X
    end
end)
SwipeRegion.InputEnded:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.Touch
        or input.UserInputType == Enum.UserInputType.MouseButton1) and swipeStart then
        local delta = input.Position.X - swipeStart
        if math.abs(delta) > 25 then
            if delta < 0 and currentIndex < #cardList then
                currentIndex += 1
                rebuildCarousel()
            elseif delta > 0 and currentIndex > 1 then
                currentIndex -= 1
                rebuildCarousel()
            end
        end
        swipeStart = nil
    end
end)

-- ══════════════════════════════════════════════
-- ROSTER LIST
-- ══════════════════════════════════════════════
rebuildRosterList = function()
    for _, c in ipairs(RosterScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    for i, data in ipairs(cardList) do
        local row = Instance.new("Frame", RosterScroll)
        row.Size = UDim2.new(1, 0, 0, 38)
        row.BackgroundColor3 = Color3.fromRGB(18, 18, 32)
        row.BorderSizePixel = 0
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

        local isSelected = selectedPlayer and selectedPlayer.Name == data.name
        local rStroke = Instance.new("UIStroke", row)
        rStroke.Thickness = isSelected and 1.5 or 0.7
        rStroke.Color = isSelected
            and Color3.fromRGB(90, 140, 255)
            or Color3.fromRGB(35, 35, 60)

        local av = Instance.new("ImageLabel", row)
        av.Size = UDim2.new(0, 28, 0, 28)
        av.Position = UDim2.new(0, 5, 0.5, -14)
        av.BackgroundTransparency = 1
        av.Image = data.avatarUrl or ""
        av.ScaleType = Enum.ScaleType.Fit
        Instance.new("UICorner", av).CornerRadius = UDim.new(0, 5)

        local nl = Instance.new("TextLabel", row)
        nl.Size = UDim2.new(1, -62, 1, 0)
        nl.Position = UDim2.new(0, 38, 0, 0)
        nl.BackgroundTransparency = 1
        nl.Text = data.name
        nl.TextSize = 9
        nl.Font = Enum.Font.GothamBold
        nl.TextColor3 = isSelected
            and Color3.fromRGB(200, 215, 255)
            or Color3.fromRGB(140, 150, 200)
        nl.TextTruncate = Enum.TextTruncate.AtEnd
        nl.TextXAlignment = Enum.TextXAlignment.Left

        local del = Instance.new("TextButton", row)
        del.Size = UDim2.new(0, 20, 0, 20)
        del.Position = UDim2.new(1, -24, 0.5, -10)
        del.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
        del.BorderSizePixel = 0
        del.Text = "×"
        del.TextColor3 = Color3.fromRGB(255, 255, 255)
        del.TextSize = 11
        del.Font = Enum.Font.GothamBold
        del.ZIndex = 5
        Instance.new("UICorner", del).CornerRadius = UDim.new(0, 5)

        local btn = Instance.new("TextButton", row)
        btn.Size = UDim2.new(1, -28, 1, 0)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.BorderSizePixel = 0

        local capData, capIdx = data, i
        btn.MouseButton1Click:Connect(function()
            selectedPlayer = {Name = capData.name, UserId = capData.userId}
            for j, d in ipairs(cardList) do
                if d.name == capData.name then currentIndex = j break end
            end
            rebuildCarousel()
            SelectedLabel.Text = capData.name
            StatusLabel.Text = ""
        end)

        del.MouseButton1Click:Connect(function()
            table.remove(cardList, capIdx)
            if currentIndex > #cardList and currentIndex > 1 then currentIndex -= 1 end
            if selectedPlayer and selectedPlayer.Name == capData.name then
                selectedPlayer = nil
                SelectedLabel.Text = "No player selected"
            end
            saveToFile()
            rebuildCarousel()
            rebuildRosterList()
            StatusLabel.TextColor3 = Color3.fromRGB(220, 100, 100)
            StatusLabel.Text = "Removed: " .. capData.name
        end)
    end

    task.wait()
    RosterScroll.CanvasSize = UDim2.new(0, 0, 0, RLayout.AbsoluteContentSize.Y + 8)
end

-- ══════════════════════════════════════════════
-- ROSTER OPEN/CLOSE
-- ══════════════════════════════════════════════
local function updateRosterPos()
    local mp = MainPanel.AbsolutePosition
    RosterPanel.Position = UDim2.new(0, mp.X - 168, 0, mp.Y)
end

local function openRoster()
    updateRosterPos()
    RosterPanel.Visible = true
    rosterOpen = true
    RosterBtn.TextColor3 = Color3.fromRGB(90, 140, 255)
    rebuildRosterList()
end

local function closeRoster()
    RosterPanel.Visible = false
    rosterOpen = false
    RosterBtn.TextColor3 = Color3.fromRGB(150, 160, 255)
end

RosterBtn.MouseButton1Click:Connect(function()
    if rosterOpen then closeRoster() else openRoster() end
end)

-- ══════════════════════════════════════════════
-- DRAGGABLE
-- ══════════════════════════════════════════════
do
    local dragging, dragStart, startPos = false, nil, nil
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = MainPanel.Position
        end
    end)
    TitleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            MainPanel.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y)
            if rosterOpen then updateRosterPos() end
        end
    end)
end

do
    local dragging, dragStart, startPos = false, nil, nil
    MinimizedBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = MinimizedBtn.Position
        end
    end)
    MinimizedBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            MinimizedBtn.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
end

